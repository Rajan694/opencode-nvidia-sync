NVIDIA_API_KEY=your key here

# Full path to your OpenCode config
OPENCODE_CONFIG=address of OPENCODE_CONFIG('/home/user/.config/opencode/opencode.jsonc')

# NVIDIA endpoint
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Number of concurrent model tests
CONCURRENCY=5

# Timeout per model (ms)
TIMEOUT=12000